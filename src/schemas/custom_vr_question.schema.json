{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "VRQuestionSchema",
    "type": "object",
    "properties": {
        "id": {
            "type": "string",
            "description": "A unique identifier for the puzzle."
        },
        "topic": {
            "type": "string",
            "enum": [
                "analogies",
                "odd_one_out",
                "synonyms",
                "antonyms",
                "number_sequence",
                "letter_sequence"
            ],
            "description": "The category of the logic or linguistic puzzle."
        },
        "question": {
            "type": "string",
            "description": "The main text of the question or the starting sequence/pair."
        },
        "options": {
            "type": "array",
            "minItems": 4,
            "maxItems": 4,
            "items": {
                "type": "string"
            },
            "description": "Exactly 4 multiple-choice text options."
        },
        "correctIndex": {
            "type": "integer",
            "enum": [
                0,
                1,
                2,
                3
            ],
            "description": "The zero-based index of the correct answer."
        },
        "explanation": {
            "type": "string",
            "description": "A clear explanation of the logic behind the correct answer."
        }
    },
    "required": [
        "id",
        "topic",
        "question",
        "options",
        "correctIndex",
        "explanation"
    ]
}